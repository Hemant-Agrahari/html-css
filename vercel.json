{
  "version": 2,
  "buildCommand": "node build.js",
  "outputDirectory": ".",
  "cleanUrls": true,
  "rewrites": [
    {
      "source": "/",
      "destination": "/dist/index.html"
    },
    {
      "source": "/(assets|pages|shared)/(.*)",
      "destination": "/$1/$2"
    },
    {
      "source": "/(.*)",
      "destination": "/dist/$1"
    }
  ]
}
